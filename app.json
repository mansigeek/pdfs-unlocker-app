{
  "expo": {
    "name": "PDF Unlocker",
    "slug": "pdfs-unlocker-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pdfsunlockerapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pdfsunlocker.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow PDF Unlocker to save unlocked PDF files.",
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "android": {
      "package": "com.pdfsunlocker.app",
      "adaptiveIcon": {
        "backgroundColor": "#0055FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fcfcfc",
          "dark": {
            "backgroundColor": "#050505"
          }
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "80d41349-5426-484b-953f-49764296367e"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/80d41349-5426-484b-953f-49764296367e"
    }
  }
}
